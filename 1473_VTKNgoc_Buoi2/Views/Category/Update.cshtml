@model _1473_VTKNgoc_Buoi2.Models.Category

@{
    ViewData["Title"] = "Sửa danh mục";
}

<div class="category-add-wrapper">

    <div class="category-add-card">

        <div class="category-left">
            <span class="category-add-badge">
                <i class="fa fa-pen"></i>
                EDIT CATEGORY
            </span>

            <h1>Sửa danh mục</h1>

            <p>
                Cập nhật tên danh mục để quản lý sản phẩm PetHome rõ ràng hơn.
            </p>

            
        </div>

        <div class="category-right">
            <h2>
                <i class="fa fa-folder-open"></i>
                Thông tin danh mục
            </h2>

            <form asp-action="Update" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="form-item">
                    <label asp-for="Name">
                        <i class="fa fa-tag"></i>
                        Tên danh mục
                    </label>

                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Nhập tên danh mục..." />
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-save">
                        <i class="fa fa-save"></i>
                        Cập nhật
                    </button>

                    <a asp-action="Index" class="btn-back">
                        <i class="fa fa-arrow-left"></i>
                        Quay lại
                    </a>
                </div>
            </form>
        </div>

    </div>

</div>