@using _1473_VTKNgoc_Buoi3.Models

@{
    ViewData["Title"] = "Dashboard doanh thu";
    decimal totalRevenue = ViewBag.TotalRevenue ?? 0;
    int totalOrders = ViewBag.TotalOrders ?? 0;
    int completedOrders = ViewBag.CompletedOrders ?? 0;
    int pendingOrders = ViewBag.PendingOrders ?? 0;
    int cancelledOrders = ViewBag.CancelledOrders ?? 0;
    decimal aov = ViewBag.Aov ?? 0;
    decimal conversionRate = ViewBag.ConversionRate ?? 0;
    decimal productRevenue = ViewBag.ProductRevenue ?? 0;
    decimal serviceRevenue = ViewBag.ServiceRevenue ?? 0;
    var topProducts = ViewBag.TopProducts as IEnumerable<TopProductViewModel>
        ?? Enumerable.Empty<TopProductViewModel>();
    var recentOrders = ViewBag.RecentOrders as IEnumerable<Order>
        ?? Enumerable.Empty<Order>();
}

<section class="admin-manage-page revenue-dashboard-page">
    <div class="admin-manage-head">
        <div>
            <span>Admin Console</span>
            <h1>Dashboard doanh thu</h1>
            <p>Theo dõi nhanh hiệu suất kinh doanh, xu hướng doanh thu, đơn hàng mới và các sản phẩm đang bán tốt nhất.</p>
        </div>
        <div class="admin-head-actions">
            <a class="admin-create-link soft" asp-controller="Product" asp-action="Add">Thêm sản phẩm</a>
            <a class="admin-create-link" asp-action="Orders">Quản lý đơn hàng</a>
        </div>
    </div>

    <div class="admin-revenue-grid kpi-grid">
        <article>
            <span>Tổng doanh thu</span>
            <strong>@totalRevenue.ToString("N0") VNĐ</strong>
        </article>
        <article>
            <span>Tổng đơn hàng</span>
            <strong>@totalOrders</strong>
        </article>
        <article>
            <span>AOV</span>
            <strong>@aov.ToString("N0") VNĐ</strong>
        </article>
        <article>
            <span>Tỷ lệ chuyển đổi</span>
            <strong>@conversionRate%</strong>
        </article>
    </div>

    <div class="admin-dashboard-grid revenue-dashboard-grid">
        <section class="admin-manage-card admin-chart-card dashboard-chart-large">
            <h2>Xu hướng doanh thu</h2>
            <p class="admin-muted">Doanh thu theo ngày từ các đơn đã hoàn tất</p>
            <canvas id="revenueTrendChart" height="168"></canvas>
        </section>

        <section class="admin-manage-card top-products-card dashboard-top-products">
            <h2>Sản phẩm bán chạy</h2>
            @if (!topProducts.Any())
            {
                <p class="admin-muted">Chưa có dữ liệu sản phẩm.</p>
            }
            else
            {
                @foreach (var product in topProducts.Take(5))
                {
                    <div>
                        <strong>@product.Name</strong>
                        <span>Đã bán @product.Quantity - @product.Revenue.ToString("N0") VNĐ</span>
                    </div>
                }
            }
        </section>
    </div>

    <div class="dashboard-extra-grid">
        <section class="admin-manage-card dashboard-breakdown-card">
            <h2>Cơ cấu doanh thu</h2>
            <div>
                <span>Sản phẩm</span>
                <strong>@productRevenue.ToString("N0") VNĐ</strong>
            </div>
            <div>
                <span>Dịch vụ</span>
                <strong>@serviceRevenue.ToString("N0") VNĐ</strong>
            </div>
        </section>

        <section class="admin-manage-card dashboard-status-card">
            <h2>Trạng thái đơn hàng</h2>
            <div>
                <span>Hoàn tất</span>
                <strong>@completedOrders</strong>
            </div>
            <div>
                <span>Đang xử lý</span>
                <strong>@pendingOrders</strong>
            </div>
            <div>
                <span>Đã hủy</span>
                <strong>@cancelledOrders</strong>
            </div>
        </section>

        <section class="admin-manage-card dashboard-actions-card">
            <h2>Thao tác nhanh</h2>
            <a asp-controller="Product" asp-action="Add">Thêm sản phẩm</a>
            <a asp-controller="Product" asp-action="Add" asp-route-type="service">Thêm dịch vụ</a>
            <a asp-controller="Admin" asp-action="Vouchers">Tạo voucher</a>
        </section>
    </div>

    <section class="admin-manage-card dashboard-recent-orders">
        <div class="dashboard-card-title">
            <div>
                <h2>Đơn hàng gần đây</h2>
                <span>Các giao dịch mới nhất trong hệ thống</span>
            </div>
            <a asp-action="Orders">Xem tất cả</a>
        </div>

        @if (!recentOrders.Any())
        {
            <p class="admin-muted">Chưa có đơn hàng mới.</p>
        }
        else
        {
            <table class="admin-manage-table">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in recentOrders)
                    {
                        <tr>
                            <td><strong>#@order.Id</strong></td>
                            <td>@order.CustomerName</td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@order.TotalAmount.ToString("N0") VNĐ</td>
                            <td><span class="admin-status-final">@order.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (() => {
            const canvas = document.getElementById("revenueTrendChart");
            if (!canvas || !window.Chart) {
                return;
            }

            new Chart(canvas, {
                type: "line",
                data: {
                    labels: @Html.Raw(ViewBag.RevenueChartLabels ?? "[]"),
                    datasets: [{
                        label: "Doanh thu",
                        data: @Html.Raw(ViewBag.RevenueChartValues ?? "[]"),
                        borderColor: "#a34216",
                        backgroundColor: "rgba(163, 66, 22, .14)",
                        pointBackgroundColor: "#f05a24",
                        pointBorderColor: "#ffffff",
                        pointRadius: 4,
                        fill: true,
                        tension: .36
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: context => `${new Intl.NumberFormat("vi-VN").format(context.parsed.y)} VNĐ`
                            }
                        }
                    },
                    scales: {
                        x: { grid: { display: false } },
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: value => `${new Intl.NumberFormat("vi-VN").format(value)}`
                            }
                        }
                    }
                }
            });
        })();
    </script>
}
