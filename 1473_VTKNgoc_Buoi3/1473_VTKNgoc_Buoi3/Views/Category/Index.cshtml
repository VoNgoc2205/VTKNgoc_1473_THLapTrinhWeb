@model IEnumerable<_1473_VTKNgoc_Buoi3.Models.Category>

@{
    ViewData["Title"] = "Quản lý danh mục";
    var categories = Model.ToList();
}

<section class="admin-page">
    <main class="admin-shell category-admin-shell category-admin-soft">
        <div class="category-admin-head">
            <div>
                <span class="category-admin-kicker">PetLounge Management</span>
                <h1>Quản lý danh mục</h1>
                <p>Sắp xếp và quản lý các nhóm sản phẩm, phụ kiện, dịch vụ chăm sóc thú cưng trong cửa hàng.</p>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Add">
                    <i class="fa-solid fa-plus"></i>
                    Thêm danh mục mới
                </a>
            }
        </div>

        <form class="category-summary-row" asp-action="Index" method="get">
            <article class="category-stat-card">
                <div class="stat-icon warm">
                    <i class="fa-solid fa-layer-group"></i>
                </div>
                <div>
                    <span>Tổng danh mục</span>
                    <strong>@categories.Count</strong>
                </div>
            </article>

            <article class="category-stat-card">
                <div class="stat-icon green">
                    <i class="fa-solid fa-box-open"></i>
                </div>
                <div>
                    <span>Sản phẩm & dịch vụ</span>
                    <strong>@categories.Sum(c => c.Products?.Count ?? 0)</strong>
                </div>
            </article>

            <article class="category-filter-card">
                <input class="filter-input" name="q" value="@ViewBag.Search" placeholder="Tìm danh mục..." />
                <select class="filter-input" name="sort">
                    <option value="">Mới tạo</option>
                    <option value="name">Theo tên</option>
                    <option value="count-desc">Nhiều mục nhất</option>
                </select>
                <button type="submit">
                    <i class="fa-solid fa-filter"></i>
                    Lọc
                </button>
            </article>
        </form>

        <section class="category-table-card refined-category-table">
            <table class="category-admin-table">
                <thead>
                    <tr>
                        <th>Tên danh mục</th>
                        <th>Mô tả</th>
                        <th>Số lượng</th>

                        @if (User.IsInRole("Admin"))
                        {
                            <th>Thao tác</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var category in categories)
                    {
                        <tr>
                            <td>
                                <div class="category-name-cell">
                                    <span>@category.Name.Substring(0, 1).ToUpper()</span>
                                    <strong>@category.Name</strong>
                                </div>
                            </td>

                            <td>
                                <p class="category-desc">
                                    Nhóm @category.Name.ToLower() giúp khách hàng chọn đúng sản phẩm, phụ kiện và dịch vụ phù hợp cho thú cưng.
                                </p>
                            </td>

                            <td>
                                <em>@(category.Products?.Count ?? 0) mục</em>
                            </td>

                            @if (User.IsInRole("Admin"))
                            {
                                <td>
                                    <div class="category-row-actions">
                                        <a asp-action="Update"
                                           asp-route-id="@category.Id"
                                           title="Sửa">
                                            <i class="fa-solid fa-pen"></i>
                                            Sửa
                                        </a>

                                        <a class="danger"
                                           asp-action="Delete"
                                           asp-route-id="@category.Id"
                                           title="Xóa">
                                            <i class="fa-regular fa-trash-can"></i>
                                            Xóa
                                        </a>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>

            <div class="category-table-footer">
                <span>Hiển thị @categories.Count danh mục trong hệ thống PetLounge</span>
                <div>
                    <button type="button" disabled><i class="fa-solid fa-chevron-left"></i></button>
                    <strong>1</strong>
                    <button type="button"><i class="fa-solid fa-chevron-right"></i></button>
                </div>
            </div>
        </section>
    </main>
</section>
