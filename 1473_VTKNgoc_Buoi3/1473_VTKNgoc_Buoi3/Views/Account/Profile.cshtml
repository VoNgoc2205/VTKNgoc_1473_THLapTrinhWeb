@model _1473_VTKNgoc_Buoi3.Models.ApplicationUser

@{
    ViewData["Title"] = "Thông tin cá nhân";
    var avatar = string.IsNullOrEmpty(Model.AvatarUrl)
        ? "/images/avatar-default.jpg"
        : Model.AvatarUrl;
    var completedOrderCount = ViewBag.CompletedOrderCount as int? ?? 0;
    var memberRank = ViewBag.MemberRank as string ?? "Hạng Thành viên Đồng";
    var nextRankRemaining = 10 - completedOrderCount % 10;
    var nextRankText = completedOrderCount >= 30
        ? "Bạn đang ở hạng cao nhất hiện tại."
        : $"Còn {nextRankRemaining} đơn nữa để lên cấp tiếp theo.";
}

<section class="account-page-shared">
    <section class="account-content">
        <div class="account-title">
            <span class="account-kicker">PetLounge Account</span>
            <h1>Thông tin cá nhân</h1>
            <p>Cập nhật hồ sơ, ảnh đại diện và thông tin liên hệ để PetLounge hỗ trợ bạn nhanh hơn.</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success account-alert">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger account-alert">
                @TempData["Error"]
            </div>
        }

        <section class="member-reward-card account-member-card">
            <div>
                <span>Hạng thành viên hiện tại</span>
                <strong>@memberRank</strong>
            </div>
            <div>
                <span>Số đơn đã tính hạng</span>
                <strong>@completedOrderCount đơn</strong>
                <small>@nextRankText</small>
            </div>
        </section>

        <form asp-action="Profile"
              method="post"
              enctype="multipart/form-data"
              class="account-form">

            @Html.AntiForgeryToken()

            <section class="account-card account-avatar-card">
                <div class="account-avatar-wrap">
                    <img id="avatarPreview" src="@avatar" alt="Ảnh đại diện" />
                    <label for="AvatarFile" title="Tải ảnh mới">
                        <i class="fa-solid fa-pen"></i>
                    </label>
                </div>

                <div class="account-avatar-copy">
                    <h2>Ảnh đại diện</h2>
                    <p>Hỗ trợ JPG, PNG, GIF và WEBP. Ảnh mới sẽ thay thế ảnh hiện tại sau khi lưu.</p>
                    <div class="account-avatar-actions">
                        <label for="AvatarFile">Tải ảnh lên</label>
                        
                    </div>
                    <input id="AvatarFile"
                           type="file"
                           name="AvatarFile"
                           accept="image/*"
                           hidden />
                    <small id="avatarFileName" class="account-avatar-note">Chưa chọn ảnh mới</small>
                </div>
            </section>

            <section class="account-card">
                <h2 class="account-section-title">
                    <i class="fa-regular fa-address-card"></i>
                    Chi tiết cá nhân
                </h2>

                <div class="account-grid">
                    <div class="account-field">
                        <label asp-for="FullName">Họ và tên</label>
                        <input asp-for="FullName" placeholder="Nhập họ và tên" />
                        <span asp-validation-for="FullName" class="text-danger account-validation"></span>
                    </div>

                    <div class="account-field account-email-field">
                        <label>Email</label>
                        <div>
                            <input value="@Model.Email" readonly />
                            <span>
                                <i class="fa-regular fa-circle-check"></i>
                                @(Model.EmailConfirmed ? "Đã xác minh" : "Chưa xác minh")
                            </span>
                        </div>
                    </div>

                    <div class="account-field">
                        <label asp-for="PhoneNumber">Số điện thoại</label>
                        <input asp-for="PhoneNumber" placeholder="Nhập số điện thoại" />
                        <span asp-validation-for="PhoneNumber" class="text-danger account-validation"></span>
                    </div>

                    <div class="account-field">
                        <label asp-for="BirthDate">Ngày sinh</label>
                        <input asp-for="BirthDate" type="date" />
                        <span asp-validation-for="BirthDate" class="text-danger account-validation"></span>
                    </div>

                    <div class="account-field account-radio-field">
                        <label>Giới tính</label>
                        <div class="account-radio-row">
                            <label>
                                <input asp-for="Gender" type="radio" value="Nam" />
                                <span>Nam</span>
                            </label>
                            <label>
                                <input asp-for="Gender" type="radio" value="Nữ" />
                                <span>Nữ</span>
                            </label>
                            <label>
                                <input asp-for="Gender" type="radio" value="Khác" />
                                <span>Khác</span>
                            </label>
                        </div>
                    </div>
                </div>
            </section>

            <section class="account-card">
                <h2 class="account-section-title">
                    <i class="fa-solid fa-location-dot"></i>
                    Địa chỉ liên hệ
                </h2>

                <div class="account-grid">
                    <div class="account-field account-full">
                        <label asp-for="Address">Địa chỉ</label>
                        <input asp-for="Address" placeholder="Số nhà, tên đường, phường/xã, quận/huyện, thành phố" />
                        <span asp-validation-for="Address" class="text-danger account-validation"></span>
                    </div>
                </div>
            </section>

            <section class="account-card account-security-card">
                <div class="account-security-copy">
                    <span>
                        <i class="fa-solid fa-clock-rotate-left"></i>
                    </span>
                    <div>
                        <h2>Bảo mật tài khoản</h2>
                        <p>Cập nhật mật khẩu định kỳ để bảo vệ tài khoản của bạn.</p>
                    </div>
                </div>

                <a asp-action="ChangePassword">Đổi mật khẩu</a>
            </section>

            <section class="account-history-shortcuts">
                <a asp-action="OrderHistory">
                    <i class="fa-solid fa-box-open"></i>
                    <span>
                        <strong>Lịch sử đơn hàng</strong>
                        <small>Đang giao, đã nhận, đã hủy...</small>
                    </span>
                </a>

                <a asp-action="ServiceHistory">
                    <i class="fa-solid fa-calendar-check"></i>
                    <span>
                        <strong>Lịch sử đặt dịch vụ</strong>
                        <small>Lịch hẹn, xác nhận và hoàn thành</small>
                    </span>
                </a>
            </section>

            <div class="account-form-actions">
                <a asp-controller="Home" asp-action="Index">Hủy</a>
                <button type="submit">Lưu thay đổi</button>
            </div>
        </form>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const avatarInput = document.getElementById('AvatarFile');
        const avatarPreview = document.getElementById('avatarPreview');
        const avatarFileName = document.getElementById('avatarFileName');

        avatarInput?.addEventListener('change', function () {
            const file = this.files && this.files[0];

            if (!file) {
                avatarFileName.textContent = 'Chưa chọn ảnh mới';
                return;
            }

            avatarFileName.textContent = file.name;

            const reader = new FileReader();
            reader.onload = function (event) {
                avatarPreview.src = event.target.result;
            };
            reader.readAsDataURL(file);
        });
    </script>
}
