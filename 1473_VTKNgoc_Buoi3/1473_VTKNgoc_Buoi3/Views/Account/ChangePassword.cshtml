@model _1473_VTKNgoc_Buoi3.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<section class="account-page-shared">
    <section class="account-content account-password-content">
        <div class="account-title">
            <span class="account-kicker">PetLounge Security</span>
            <h1>Đổi mật khẩu</h1>
            <p>Cập nhật mật khẩu mới để bảo vệ tài khoản và các thông tin đặt hàng của bạn.</p>
        </div>

        <form asp-action="ChangePassword"
              method="post"
              class="account-form">
            @Html.AntiForgeryToken()

            <section class="account-card account-password-card">
                <h2 class="account-section-title">
                    <i class="fa-solid fa-shield-halved"></i>
                    Bảo mật tài khoản
                </h2>

                <div asp-validation-summary="ModelOnly" class="text-danger account-validation-summary"></div>

                <div class="account-grid">
                    <div class="account-field account-full">
                        <label asp-for="CurrentPassword">Mật khẩu hiện tại</label>
                        <input asp-for="CurrentPassword" placeholder="Nhập mật khẩu hiện tại" />
                        <span asp-validation-for="CurrentPassword" class="text-danger account-validation"></span>
                    </div>

                    <div class="account-field">
                        <label asp-for="NewPassword">Mật khẩu mới</label>
                        <input asp-for="NewPassword" placeholder="Nhập mật khẩu mới" />
                        <span asp-validation-for="NewPassword" class="text-danger account-validation"></span>
                    </div>

                    <div class="account-field">
                        <label asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" placeholder="Nhập lại mật khẩu mới" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger account-validation"></span>
                    </div>
                </div>
            </section>

            <div class="account-form-actions">
                <a asp-action="Profile">Quay lại</a>
                <button type="submit">Cập nhật mật khẩu</button>
            </div>
        </form>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
