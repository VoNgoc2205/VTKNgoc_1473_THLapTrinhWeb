@model List<_1473_VTKNgoc_Buoi3.Models.Order>

@{
    ViewData["Title"] = "Lịch sử đặt dịch vụ";
}

<section class="account-history-page">
    <div class="account-title">
        <span class="account-kicker">PetLounge Booking</span>
        <h1>Lịch sử đặt dịch vụ</h1>
        <p>Quản lý lịch hẹn chăm sóc thú cưng và theo dõi trạng thái xác nhận từ cửa hàng.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success admin-page-alert">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger admin-page-alert">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="history-empty">
            <h2>Bạn chưa đặt dịch vụ</h2>
            <p>Chọn dịch vụ chăm sóc phù hợp và đặt lịch cho thú cưng của bạn.</p>
            <a asp-controller="Product" asp-action="Services">Xem dịch vụ</a>
        </div>
    }
    else
    {
        <div class="history-list">
            @foreach (var order in Model)
            {
                var serviceItems = order.Items.Where(i => i.IsService).ToList();

                foreach (var item in serviceItems)
                {
                    var canCancel = item.ItemStatus == "Chờ xác nhận lịch" || item.ItemStatus == "Đã xác nhận";

                    <article class="history-order-card service-history-card">
                        <div class="history-order-head">
                            <div>
                                <strong>@item.ProductName</strong>
                                <span>Đơn @order.Id - @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <em>@item.ItemStatus</em>
                        </div>

                        <div class="service-history-info">
                            <div>
                                <span>Lịch hẹn</span>
                                <strong>@item.AppointmentAt?.ToString("dd/MM/yyyy HH:mm")</strong>
                            </div>
                            <div>
                                <span>Thú cưng</span>
                                <strong>@item.PetName (@item.PetType, @item.PetAge, @item.PetBreed)</strong>
                            </div>
                            <div>
                                <span>Chi phí</span>
                                <strong>@item.Total.ToString("N0") VNĐ</strong>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(item.CustomerNote))
                        {
                            <p class="service-history-note">@item.CustomerNote</p>
                        }

                        @if (canCancel)
                        {
                            <form asp-action="CancelService" method="post" class="history-cancel-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" onclick="return confirm('Bạn chắc chắn muốn hủy lịch hẹn này?')">Hủy lịch hẹn</button>
                            </form>
                        }
                    </article>
                }
            }
        </div>
    }
</section>
