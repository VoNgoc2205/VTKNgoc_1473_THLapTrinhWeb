@model IEnumerable<_1473_VTKNgoc_Buoi3.Models.Product>

@{
    var isService = ViewBag.Context == "Service";
    var products = Model.ToList();
    var itemLabel = isService ? "dịch vụ" : "sản phẩm";
    var title = isService ? "Quản lý dịch vụ PetLounge" : "Danh sách sản phẩm PetLounge";
    var subtitle = isService
        ? "Theo dõi và tìm kiếm các dịch vụ chăm sóc thú cưng."
        : "Theo dõi và tìm kiếm sản phẩm trong cửa hàng.";
    var addRoute = isService ? "service" : null;
    var indexAction = isService ? "Services" : "Index";
    ViewData["Title"] = title;
}

<section class="shop-page">
    <section class="shop-hero">
        <img src="~/images/pet-banner.jpg" alt="@title" />
        <div class="shop-hero-copy">
            <span>@(isService ? "Dịch vụ" : "Sản phẩm")</span>
            <h1>@title</h1>
            <p>@subtitle</p>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Product"
                   asp-action="Add"
                   asp-route-type="@addRoute">
                    Thêm @itemLabel
                </a>
            }
        </div>
    </section>

    <div class="shop-layout">
        <aside class="filter-panel">
            <form asp-action="@indexAction" method="get">
                <h2>Bộ lọc</h2>

                <div class="filter-group">
                    <h3>Từ khóa</h3>
                    <input class="filter-input" name="q" value="@ViewBag.Search" placeholder="Nhập tên hoặc mô tả..." />
                </div>

                <div class="filter-group">
                    <h3>Danh mục</h3>
                    <select class="filter-input" name="categoryId" asp-items="ViewBag.Categories">
                        <option value="">Tất cả danh mục</option>
                    </select>
                </div>

                <div class="filter-group">
                    <h3>Khoảng giá</h3>
                    <input class="filter-input" name="minPrice" type="number" value="@ViewBag.MinPrice" placeholder="Giá từ" />
                    <input class="filter-input" name="maxPrice" type="number" value="@ViewBag.MaxPrice" placeholder="Giá đến" />
                </div>

                <div class="filter-group">
                    <h3>Sắp xếp</h3>
                    <select class="filter-input" name="sort">
                        <option value="">Mới cập nhật</option>
                        <option value="price-asc">Giá thấp đến cao</option>
                        <option value="price-desc">Giá cao đến thấp</option>
                        <option value="name">Tên A-Z</option>
                    </select>
                </div>

                <button type="submit">Áp dụng bộ lọc</button>
                <a class="reset-filter-link" asp-action="@indexAction">Xóa bộ lọc</a>
            </form>
        </aside>

        <section class="shop-results">
            <div class="results-toolbar">
                <span>@products.Count @itemLabel trong hệ thống</span>

                @if (User.IsInRole("Admin"))
                {
                    <div class="results-actions">
                        <a class="add-product-link"
                           asp-action="Add"
                           asp-route-type="@addRoute">
                            Thêm @itemLabel
                        </a>
                    </div>
                }
            </div>

            @if (!products.Any())
            {
                <div class="empty-state">
                    <h2>Chưa có @itemLabel phù hợp</h2>
                    <p>Hãy thử đổi bộ lọc.</p>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Add" asp-route-type="@addRoute">
                            Thêm @itemLabel
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="shop-grid">
                    @foreach (var product in products)
                    {
                        <article class="shop-card clickable-product-card"
                                 data-detail-url="@Url.Action("Display", "Product", new { id = product.Id, type = addRoute })">
                            <a asp-action="Display"
                               asp-route-id="@product.Id"
                               asp-route-type="@addRoute"
                               class="shop-card-image">

                                @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" />
                                }
                                else
                                {
                                    <span class="image-placeholder">Chưa có ảnh</span>
                                }
                            </a>

                            <div class="shop-card-body">
                                <small>Danh mục: @(product.Category?.Name ?? "Chưa phân loại")</small>
                                <h2>
                                    <a asp-action="Display"
                                       asp-route-id="@product.Id"
                                       asp-route-type="@addRoute">
                                        @product.Name
                                    </a>
                                </h2>
                                <p>@product.Description</p>

                                <div class="shop-card-bottom">
                                    <strong>@product.Price.ToString("N0") VNĐ</strong>
                                </div>

                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="shop-card-actions admin-card-actions">
                                        <a class="edit-btn"
                                           asp-action="Update"
                                           asp-route-id="@product.Id"
                                           asp-route-type="@addRoute">
                                            <i class="fa-solid fa-pen"></i>
                                            Sửa
                                        </a>

                                        <a class="delete-btn"
                                           asp-action="Delete"
                                           asp-route-id="@product.Id"
                                           asp-route-type="@addRoute">
                                            <i class="fa-solid fa-trash"></i>
                                            Xóa
                                        </a>
                                    </div>
                                }
                                else if (User.Identity?.IsAuthenticated == true && isService)
                                {
                                    <div class="shop-card-actions">
                                        <a class="book-service-btn"
                                           asp-controller="Cart"
                                           asp-action="BookService"
                                           asp-route-id="@product.Id">
                                            <i class="fa-solid fa-calendar-check"></i>
                                            Đặt lịch
                                        </a>
                                    </div>
                                }
                                else if (User.Identity?.IsAuthenticated == true && !isService)
                                {
                                    <div class="shop-card-purchase" data-quantity-box>
                                        <div class="shop-quantity-stepper">
                                            <button type="button" data-qty-minus aria-label="Giảm số lượng">-</button>
                                            <input type="number" name="quantity" value="1" min="1" max="99" inputmode="numeric" />
                                            <button type="button" data-qty-plus aria-label="Tăng số lượng">+</button>
                                        </div>

                                        <div class="shop-card-actions">
                                            <form asp-controller="Cart" asp-action="BuyNow" method="get">
                                                <input type="hidden" name="id" value="@product.Id" />
                                                <input type="hidden" name="quantity" value="1" data-qty-target />
                                                <button class="buy-now-btn" type="submit">
                                                    <i class="fa-solid fa-bolt"></i>
                                                    Mua ngay
                                                </button>
                                            </form>

                                            <form asp-controller="Cart" asp-action="AddToCart" method="get">
                                                <input type="hidden" name="id" value="@product.Id" />
                                                <input type="hidden" name="quantity" value="1" data-qty-target />
                                                <button class="add-cart-btn" type="submit">
                                                    <i class="fa-solid fa-cart-plus"></i>
                                                    Thêm vào giỏ
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll("[data-quantity-box]").forEach((box) => {
            const visibleInput = box.querySelector(".shop-quantity-stepper input");
            const targets = box.querySelectorAll("[data-qty-target]");
            const sync = () => {
                const value = Math.min(99, Math.max(1, parseInt(visibleInput.value || "1", 10)));
                visibleInput.value = value;
                targets.forEach((target) => target.value = value);
            };

            box.querySelector("[data-qty-minus]")?.addEventListener("click", () => {
                visibleInput.value = (parseInt(visibleInput.value || "1", 10) - 1).toString();
                sync();
            });

            box.querySelector("[data-qty-plus]")?.addEventListener("click", () => {
                visibleInput.value = (parseInt(visibleInput.value || "1", 10) + 1).toString();
                sync();
            });

            visibleInput.addEventListener("input", sync);
            sync();
        });

        document.querySelectorAll(".clickable-product-card").forEach((card) => {
            card.addEventListener("click", (event) => {
                if (event.target.closest("a, button, input, form, select, textarea")) {
                    return;
                }

                window.location.href = card.dataset.detailUrl;
            });
        });
    </script>
}
