@{
    ViewData["Title"] = "Trang chủ";
}

<section class="lounge-hero">
    <div class="lounge-hero-copy">
        <span class="lounge-badge">Chào mừng đến với PetLounge</span>
        <h1>Nơi yêu thương bắt đầu từ <span>những bàn chân nhỏ</span></h1>
        <p>PetLounge giúp bạn mua sắm phụ kiện, thức ăn, đặt lịch chăm sóc và theo dõi đơn hàng cho thú cưng trong một nơi gọn gàng.</p>

        <div class="lounge-actions">
            <a class="btn-main" asp-controller="Product" asp-action="Index">Mua sắm ngay</a>
            <a class="btn-soft" asp-controller="Product" asp-action="Services">Đặt lịch ngay</a>
        </div>
    </div>

    <div class="lounge-hero-visual">
        <img src="~/images/pet-banner.jpg" alt="PetLounge" />
        <div class="hero-note">
            <strong>Pet Care</strong>
            <span>Sản phẩm tốt, lịch hẹn rõ ràng</span>
        </div>
    </div>
</section>

@if (User.IsInRole("Admin"))
{
    <section class="home-band">
        <div class="home-section-title split">
            <div>
                <h2>Khu vực quản lý</h2>
                <p>Admin truy cập nhanh các phần quan trọng của cửa hàng.</p>
            </div>
            <a asp-controller="Admin" asp-action="Orders">Quản lý đơn hàng</a>
        </div>

        <div class="pet-card-grid">
            <article class="lounge-pet-card">
                <img src="~/images/GoiNgu.jpg" alt="Sản phẩm" />
                <div class="pet-card-body">
                    <h3>Sản phẩm</h3>
                    <p>Quản lý danh sách sản phẩm, giá bán, mô tả, hình ảnh và danh mục.</p>
                    <div class="pet-tags">
                        <span>Tìm kiếm</span>
                        <span>Lọc giá</span>
                    </div>
                    <a asp-controller="Product" asp-action="Index">Mở sản phẩm</a>
                </div>
            </article>

            <article class="lounge-pet-card">
                <img src="~/images/tam.jpg" alt="Dịch vụ" />
                <div class="pet-card-body">
                    <h3>Dịch vụ</h3>
                    <p>Quản lý gói tắm, spa, chăm sóc sức khỏe và lịch đặt của khách.</p>
                    <div class="pet-tags">
                        <span>Đặt lịch</span>
                        <span>Cập nhật</span>
                    </div>
                    <a asp-controller="Product" asp-action="Services">Mở dịch vụ</a>
                </div>
            </article>

            <article class="lounge-pet-card">
                <img src="~/images/Cat.jpg" alt="Danh mục" />
                <div class="pet-card-body">
                    <h3>Danh mục</h3>
                    <p>Sắp xếp nhóm thức ăn, phụ kiện, chăm sóc và dịch vụ cho dễ tìm.</p>
                    <div class="pet-tags">
                        <span>Thống kê</span>
                        <span>CRUD</span>
                    </div>
                    <a asp-controller="Category" asp-action="Index">Mở danh mục</a>
                </div>
            </article>

            <article class="lounge-pet-card">
                <img src="~/images/Hat.jpg" alt="Đơn hàng" />
                <div class="pet-card-body">
                    <h3>Đơn hàng</h3>
                    <p>Theo dõi doanh thu, đơn đang giao và lịch dịch vụ chờ xác nhận.</p>
                    <div class="pet-tags">
                        <span>Doanh thu</span>
                        <span>Trạng thái</span>
                    </div>
                    <a asp-controller="Admin" asp-action="Orders">Mở đơn hàng</a>
                </div>
            </article>
        </div>
    </section>
}

<section class="services-band featured-products-band">
    <div class="home-section-title centered">
        <h2>Sản phẩm nổi bật</h2>
        <p>Những món đồ được khách hàng quan tâm nhiều cho bữa ăn, giấc ngủ và chăm sóc hằng ngày của thú cưng.</p>
    </div>

    <div class="featured-product-grid">
        <article>
            <img src="~/images/Hat.jpg" alt="Hạt dinh dưỡng cho thú cưng" />
            <div>
                <span>Thức ăn</span>
                <h3>Hạt dinh dưỡng cho thú cưng</h3>
                <p>Bổ sung năng lượng, vitamin và dưỡng chất cho chó mèo mỗi ngày.</p>
                <strong>185.000 VNĐ</strong>
            </div>
        </article>

        <article>
            <img src="~/images/GoiNgu.jpg" alt="Gối ngủ thú cưng" />
            <div>
                <span>Phụ kiện</span>
                <h3>Gối ngủ thú cưng</h3>
                <p>Không gian nghỉ ngơi mềm mại, sạch sẽ và dễ đặt trong nhà.</p>
                <strong>249.000 VNĐ</strong>
            </div>
        </article>

        <article>
            <img src="~/images/Cat.jpg" alt="Nhà cây cho mèo" />
            <div>
                <span>Đồ chơi</span>
                <h3>Nhà cây cho mèo</h3>
                <p>Giúp mèo vận động, leo trèo và vui chơi an toàn hơn.</p>
                <strong>390.000 VNĐ</strong>
            </div>
        </article>
    </div>
</section>
