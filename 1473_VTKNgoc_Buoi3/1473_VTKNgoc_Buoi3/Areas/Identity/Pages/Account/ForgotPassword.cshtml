@page "/Identity/Account/ForgotPassword"
@model _1473_VTKNgoc_Buoi3.Areas.Identity.Pages.Account.ForgotPasswordModel

@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<section class="auth-page auth-page-compact">
    <section class="auth-card" aria-labelledby="forgot-title">
        <div class="auth-card-head">
            <span class="auth-kicker">PetLounge Security</span>
            <h2 id="forgot-title">Quên mật khẩu</h2>
            <p>Nhập email tài khoản để tạo liên kết đặt lại mật khẩu.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="alert alert-success auth-alert">
                @Model.Message
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ResetLink))
        {
            <div class="auth-reset-link">
                <span>Liên kết khôi phục:</span>
                <a href="@Model.ResetLink">@Model.ResetLink</a>
            </div>
        }

        <form method="post" class="auth-form">
            <div class="auth-field">
                <label asp-for="Input.Email">Email</label>
                <div class="auth-input">
                    <i class="fa-regular fa-envelope"></i>
                    <input asp-for="Input.Email" type="email" placeholder="email@vi-du.com" />
                </div>
                <span asp-validation-for="Input.Email" class="text-danger auth-validation"></span>
            </div>

            <button type="submit" class="auth-submit">
                <span>Tạo liên kết</span>
                <i class="fa-solid fa-arrow-right"></i>
            </button>
        </form>

        <p class="auth-switch">
            Nhớ mật khẩu?
            <a asp-page="/Account/Login">Đăng nhập</a>
        </p>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
