@page "/Identity/Account/ResetPassword"
@model _1473_VTKNgoc_Buoi3.Areas.Identity.Pages.Account.ResetPasswordModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<section class="auth-page auth-page-compact">
    <section class="auth-card" aria-labelledby="reset-title">
        <div class="auth-card-head">
            <span class="auth-kicker">PetLounge Security</span>
            <h2 id="reset-title">Đặt lại mật khẩu</h2>
            <p>Nhập mật khẩu mới cho tài khoản của bạn.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="alert alert-success auth-alert">
                @Model.SuccessMessage
            </div>
        }

        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary"></div>
            <input asp-for="Input.Code" type="hidden" />

            <div class="auth-field">
                <label asp-for="Input.Email">Email</label>
                <div class="auth-input">
                    <i class="fa-regular fa-envelope"></i>
                    <input asp-for="Input.Email" readonly />
                </div>
                <span asp-validation-for="Input.Email" class="text-danger auth-validation"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Password">Mật khẩu mới</label>
                <div class="auth-input">
                    <i class="fa-solid fa-lock"></i>
                    <input asp-for="Input.Password"
                           class="password-toggle-input"
                           type="password"
                           placeholder="Nhập mật khẩu mới"
                           autocomplete="new-password" />
                    <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger auth-validation"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.ConfirmPassword">Xác nhận mật khẩu</label>
                <div class="auth-input">
                    <i class="fa-solid fa-shield-halved"></i>
                    <input asp-for="Input.ConfirmPassword"
                           class="password-toggle-input"
                           type="password"
                           placeholder="Nhập lại mật khẩu mới"
                           autocomplete="new-password" />
                    <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger auth-validation"></span>
            </div>

            <button type="submit" class="auth-submit">
                <span>Cập nhật mật khẩu</span>
                <i class="fa-solid fa-arrow-right"></i>
            </button>
        </form>

        <p class="auth-switch">
            Quay lại
            <a asp-page="/Account/Login">đăng nhập</a>
        </p>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/password-toggle.js" asp-append-version="true"></script>
}
