@page "/Identity/Account/Register"
@model _1473_VTKNgoc_Buoi3.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Đăng ký";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<section class="auth-page auth-page-wide">
    <div class="auth-hero">
        <span>PetLounge Member</span>
        <h1>Tạo tài khoản mới</h1>
        <p>Lưu thông tin cá nhân, theo dõi đơn hàng và đặt dịch vụ chăm sóc thú cưng nhanh hơn.</p>
    </div>

    <section class="auth-card auth-card-wide" aria-labelledby="register-title">
        <div class="auth-card-head">
            <h2 id="register-title">Đăng ký</h2>
            <p>Điền thông tin để bắt đầu sử dụng PetLounge.</p>
        </div>

        <form method="post" enctype="multipart/form-data" class="auth-form">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger auth-alert">@Model.ErrorMessage</div>
            }

            <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary"></div>

            <div class="auth-avatar">
                <img id="registerAvatarPreview" src="~/images/avatar-default.jpg" alt="Ảnh đại diện" />
                <div>
                    <label asp-for="Input.AvatarFile">Ảnh đại diện</label>
                    <p>Chọn ảnh JPG, PNG, GIF hoặc WEBP để hồ sơ dễ nhận diện hơn.</p>
                    <input asp-for="Input.AvatarFile" id="RegisterAvatarFile" type="file" accept="image/*" />
                </div>
            </div>

            <div class="auth-grid">
                <div class="auth-field">
                    <label asp-for="Input.FullName">Họ và tên</label>
                    <div class="auth-input">
                        <i class="fa-regular fa-user"></i>
                        <input asp-for="Input.FullName" placeholder="Nguyễn Văn A" />
                    </div>
                    <span asp-validation-for="Input.FullName" class="text-danger auth-validation"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Email">Email</label>
                    <div class="auth-input">
                        <i class="fa-regular fa-envelope"></i>
                        <input asp-for="Input.Email" placeholder="email@vi-du.com" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger auth-validation"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.PhoneNumber">Số điện thoại</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-phone"></i>
                        <input asp-for="Input.PhoneNumber" placeholder="0901234567" />
                    </div>
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger auth-validation"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.BirthDate">Ngày sinh</label>
                    <div class="auth-input">
                        <i class="fa-regular fa-calendar"></i>
                        <input asp-for="Input.BirthDate" type="date" />
                    </div>
                    <span asp-validation-for="Input.BirthDate" class="text-danger auth-validation"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Gender">Giới tính</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-venus-mars"></i>
                        <select asp-for="Input.Gender">
                            <option value="">Chọn giới tính</option>
                            <option value="Nam">Nam</option>
                            <option value="Nữ">Nữ</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>
                    <span asp-validation-for="Input.Gender" class="text-danger auth-validation"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Address">Địa chỉ</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-location-dot"></i>
                        <input asp-for="Input.Address" placeholder="TP.HCM, Việt Nam" />
                    </div>
                    <span asp-validation-for="Input.Address" class="text-danger auth-validation"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Password">Mật khẩu</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-lock"></i>
                        <input asp-for="Input.Password"
                               class="password-toggle-input"
                               type="password"
                               placeholder="Nhập mật khẩu"
                               autocomplete="new-password" />
                        <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger auth-validation"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.ConfirmPassword">Xác nhận mật khẩu</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-shield-halved"></i>
                        <input asp-for="Input.ConfirmPassword"
                               class="password-toggle-input"
                               type="password"
                               placeholder="Nhập lại mật khẩu"
                               autocomplete="new-password" />
                        <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger auth-validation"></span>
                </div>
            </div>

            <button type="submit" class="auth-submit">
                <span>Tạo tài khoản</span>
                <i class="fa-solid fa-arrow-right"></i>
            </button>
        </form>

        <p class="auth-switch">
            Đã có tài khoản?
            <a asp-page="/Account/Login">Đăng nhập</a>
        </p>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/password-toggle.js" asp-append-version="true"></script>
    <script>
        const registerAvatarInput = document.getElementById('RegisterAvatarFile');
        const registerAvatarPreview = document.getElementById('registerAvatarPreview');

        registerAvatarInput?.addEventListener('change', function () {
            const file = this.files && this.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = event => {
                registerAvatarPreview.src = event.target.result;
            };
            reader.readAsDataURL(file);
        });
    </script>
}
